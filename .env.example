# Supabase project credentials (Project Settings -> API)
# The anon key is safe to expose to the browser; RLS protects the data.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key is NEVER shipped to the browser. Use it only in
# trusted server / edge-function contexts (e.g. public registration intake).
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
